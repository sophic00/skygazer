---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero" class="pt-0 pb-0">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Hey, I'm Vaibhav
      </h1>

      <p class="text-skin-base/90 mb-6 text-lg">
        Welcome to my quiet corner of the internet. I'm currently a CS undergrad
        and likes building things that run fast, accurately, and don't fall
        apart under pressure.
      </p>
    </section>

    <Hr />

    <section id="about-work" class="pt-6 pb-6">
      <h2 class="mb-6 text-2xl font-semibold tracking-wide">What I Do</h2>
      <div class="text-skin-base/90 space-y-4">
        <p>
          I love building systems from the ground up, whether that's 
          <strong class="text-skin-base">operating systems</strong>, 
          <strong class="text-skin-base">emulators</strong>, 
          <strong class="text-skin-base">compilers</strong>, or 
          <strong class="text-skin-base">large-scale backend services</strong>. 
          I'm happiest working at scale, where I can own a system end to end, design, implementation, debugging, and keeping it reliable in production.
        </p>
        <p>
          I enjoy peeling back abstractions to see how things really work, and I 
          don't mind working with legacy or opaque code if it means making the 
          system more performant and reliable.
        </p>
      </div>
    </section>

    <Hr />

    <section id="technical-skills" class="pt-6 pb-6">
      <h2 class="mb-6 text-2xl font-semibold tracking-wide">Technical Stack</h2>
      <div class="text-skin-base/90 space-y-4">
        <p>
          On the programming side, I'm very comfortable with Rust, C, Python, and Go for systems and backend work. I've also worked with Docker, Kubernetes, and distributed systems tooling. These are the instruments I reach for most often, though I'm always open to exploring whatever tool best suits the problem at hand.
        </p>
        <p>
          Beyond code, I'm deeply interested in the philosophy of computation, programming language theory, and the craft of abstraction: how great designs can be simple, powerful, and enduring.
        </p>
      </div>
    </section>



    {/* Show Hr separator if we have any posts sections to display */}
    {
      ((SITE.showFeaturedPosts && featuredPosts.length > 0) ||
        (SITE.showRecentPosts && recentPosts.length > 0)) && <Hr />
    }

    {
      SITE.showFeaturedPosts && featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-6 pb-6">
            <h2 class="mb-6 text-2xl font-semibold tracking-wide">Featured</h2>
            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
          {SITE.showRecentPosts && recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      SITE.showRecentPosts && recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-6 pb-6">
          <h2 class="mb-6 text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    {
      SITE.showAllPostsButton && (
        <div class="mt-6 text-center">
          <LinkButton href="/posts/">
            All Posts
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
        </div>
      )
    }
  </main>
  <Footer />
</Layout>
---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
// import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
// import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-0 pb-0">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Hey, I'm Vaibhav 👋
      </h1>

      <p class="text-skin-base/90 mb-6 text-lg">
        Welcome to my quiet corner of the internet. I'm a CS undergrad and like
        builds stuff that run fast, is correct, and don’t fall apart under
        pressure.
      </p>

      <p class="text-skin-base/80 mb-6 text-base">
        I find software like game engines, compilers, and operating systems
        deeply interesting. When I come across something well-built or
        technically impressive, I often think about how I’d implement it myself
        how it works, where the tradeoffs are, and what could be done
        differently. Lately, I’ve been drawn to the overlap between systems
        programming, language runtimes, and low-level internals.
      </p>
    </section>

    <Hr />

    <section id="current-work" class="pt-6 pb-6">
      <h2 class="mb-6 text-2xl font-semibold tracking-wide">
        Right now, my curiosity takes a few forms
      </h2>
      <ul class="text-skin-base/90 space-y-3">
        <li class="flex items-start">
          <span class="text-skin-accent mr-2 font-semibold">•</span>
          <span
            ><strong class="text-skin-base">Sora</strong> – An attempt to build a
            modern operating system for RISC-V in Rust.</span
          >
        </li>
        <li class="flex items-start">
          <span class="text-skin-accent mr-2 font-semibold">•</span>
          <span
            >Crafting interpreters in <strong class="text-skin-base">Zig</strong
            >.</span
          >
        </li>
        <li class="flex items-start">
          <span class="text-skin-accent mr-2 font-semibold">•</span>
          <span
            >Exploring <strong class="text-skin-base">Golang internals</strong> and
            backend profiling.</span
          >
        </li>
        <li class="flex items-start">
          <span class="text-skin-accent mr-2 font-semibold">•</span>
          <span
            >Learning the <strong class="text-skin-base">LLVM toolchain</strong>
            and compiler internals.</span
          >
        </li>
      </ul>
    </section>

    <Hr />

    <section id="interests-tech" class="pt-6 pb-6">
      <h2 class="mb-6 text-2xl font-semibold tracking-wide">Tools of trade</h2>
      <div class="text-skin-base/90 space-y-4">
        <p>
          I’m not very loyal to tools or frameworks. I’m loyal to problems. If
          something bothers me, or if I don’t understand how it works, I’ll
          probably poke at it until I do. That’s how most of my projects begin.
        </p>
        <p>
          This site is mostly a notebook for my own thinking. If you like <strong
            class="text-skin-base">operating systems</strong
          >,
          <strong class="text-skin-base">language theory</strong>,
          <strong class="text-skin-base">compilers</strong>,
          <strong class="text-skin-base">performance tuning</strong>, or the
          <strong class="text-skin-base"
            >philosophy of how software ought to be built</strong
          > — you might find something here worth your time. And if you do, I’d love
          to hear from you.
        </p>
        <div class="mt-6 text-center">
          <LinkButton
            href="/keys.asc"
            class="text-skin-accent hover:text-skin-accent/80 underline"
            title="Download PGP Public Key"
          >
            🔐 PGP Public Key
          </LinkButton>
        </div>
      </div>
    </section>

    <!-- <section id="interests-tech" class="pt-6 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide mb-6">How I Work</h2>
      <div class="text-skin-base/90 space-y-4">
        <p>
          I'm most engaged when I'm deep into problems I haven't figured out yet—whether that means 
          <strong class="text-skin-base">writing an operating system</strong>, <strong class="text-skin-base">designing a backend system</strong>, 
          <strong class="text-skin-base">building a interpreter</strong>, or sketching out ideas on paper.
        </p>
        <p>
          I rarely start with a language or framework in mind; I start with a question, a curiosity, or a constraint. 
          <strong class="text-skin-base">The tools follow</strong>. My work often spans <strong class="text-skin-base">systems programming</strong>, 
          <strong class="text-skin-base">compilers</strong>, <strong class="text-skin-base">backend architecture</strong>, 
          and the occasional detour into <strong class="text-skin-base">graphics or AI</strong>—whatever best serves the challenge at hand.
        </p>
        <p>
          I enjoy working with <strong class="text-skin-base">Rust, Go, Zig, and Python</strong>, 
          and care about building <strong class="text-skin-base">reliable systems</strong> that explore ideas 
          at the intersection of <strong class="text-skin-base">math, philosophy, and computation</strong>.
        </p>
        <div class="mt-6 text-center">
          <LinkButton 
            href="/keys.asc" 
            class="text-skin-accent hover:text-skin-accent/80 underline"
            title="Download PGP Public Key"
          >
            🔐 PGP Public Key
          </LinkButton>
        </div>
      </div>
    </section> -->

    {/* Show Hr separator if we have any posts sections to display */}
    {
      ((SITE.showFeaturedPosts && featuredPosts.length > 0) ||
        (SITE.showRecentPosts && recentPosts.length > 0)) && <Hr />
    }

    {
      SITE.showFeaturedPosts && featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
          {SITE.showRecentPosts && recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      SITE.showRecentPosts && recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    {
      SITE.showAllPostsButton && (
        <div class="my-8 text-center">
          <LinkButton href="/posts/">
            All Posts
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
        </div>
      )
    }

    <!-- <Hr /> -->

    <!-- <section id="closing-message" class="pt-12 pb-6">
      <p class="text-base text-skin-base/80 mb-8">
        Thanks for stopping by! Feel free to check out my projects, read my notes, 
        or drop by if there's an interesting topic to chat about.
      </p>

      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex flex-col sm:flex-row sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Social Links:</div>
            <Socials />
          </div>
        )
      }
    </section> -->
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

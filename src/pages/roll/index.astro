---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";
import { readFileSync } from "fs";
import { join } from "path";

interface FeedItem {
  title: string;
  link: string;
  pubDate: string;
  contentSnippet?: string;
  creator?: string;
  feedTitle?: string;
  siteUrl?: string;
}

interface BlogrollEntry {
  feedUrl: string;
  title: string;
  siteUrl: string;
  description?: string;
  latestPosts: FeedItem[];
  lastUpdated: string;
  lastFetched?: string;
  error?: string;
}

let blogrollData: BlogrollEntry[] = [];
let allPosts: FeedItem[] = [];
let lastUpdated = "";

try {
  const dataPath = join(process.cwd(), "src/data/blogroll.json");
  const data = readFileSync(dataPath, "utf-8");
  blogrollData = JSON.parse(data);

  // Combine all posts from all feeds and add feed info
  allPosts = blogrollData
    .filter(blog => !blog.error) // Filter out error feeds
    .flatMap(blog =>
      blog.latestPosts.map(post => ({
        ...post,
        feedTitle: blog.title,
        siteUrl: blog.siteUrl,
      }))
    )
    .sort((a, b) => {
      // Sort by date descending (newest first)
      const dateA = new Date(a.pubDate || 0);
      const dateB = new Date(b.pubDate || 0);
      return dateB.getTime() - dateA.getTime();
    });

  lastUpdated = blogrollData.length > 0 ? blogrollData[0].lastUpdated : "";
} catch {
  // eslint-disable-next-line no-console
  console.warn("Blogroll data not found. Run the fetch script to generate it.");
}

function formatDate(dateString: string): string {
  if (!dateString) return "";
  try {
    return new Date(dateString).toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    });
  } catch {
    return dateString;
  }
}
---

<Layout title={`Blogroll | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Blogroll" pageDesc="Stuff I like to read.">
    {
      lastUpdated && (
        <div class="mb-6 rounded-lg border bg-muted/50 p-4">
          <p class="text-muted-foreground text-sm">
            Last updated: {formatDate(lastUpdated)}
          </p>
        </div>
      )
    }

    {
      allPosts.length === 0 ? (
        <div class="py-12 text-center">
          <p class="text-muted-foreground">No blogroll data available yet.</p>
          <p class="text-muted-foreground mt-2 text-sm">
            The blogroll will be populated automatically by the GitHub Action.
          </p>
        </div>
      ) : (
        <div class="space-y-3">
          {allPosts.map(post => (
            <article class="py-2">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-muted-foreground text-base">
                  {post.pubDate && formatDate(post.pubDate)}
                </span>
                <a
                  href={post.siteUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-base text-accent decoration-dashed hover:underline"
                >
                  {post.feedTitle}
                </a>
                <span class="text-muted-foreground text-sm">
                  {new URL(post.siteUrl || '').hostname || post.siteUrl}
                </span>
              </div>
              <a
                href={post.link}
                target="_blank"
                rel="noopener noreferrer"
                class="block text-2xl font-medium transition-colors hover:text-accent decoration-dashed hover:underline leading-relaxed"
                style="word-break: break-word; hyphens: auto;"
              >
                {post.title}
              </a>
            </article>
          ))}
        </div>
      )
    }

    <div class="mt-12 rounded-lg border border-dashed bg-muted/30 p-4">
      <h3 class="mb-2 text-sm font-medium">About this Blogroll</h3>
      <p class="text-muted-foreground text-xs">
        I first came across the idea of treating a blogroll as a feed
        reader on
        <a href="https://matklad.github.io" class="underline underline-offset-2"
          >Alex Kladov’s site</a
        >. His approach struck me as both minimal and effective, and it inspired
        me to build my own version.
      </p>
    </div>
  </Main>
  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
